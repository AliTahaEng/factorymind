# Database
POSTGRES_URL=postgresql://factorymind:secret@localhost:5432/factorymind
POSTGRES_DB=factorymind
POSTGRES_USER=factorymind
POSTGRES_PASSWORD=secret

# Cache
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_S3_ENDPOINT_URL=http://localhost:4566

# AWS (LocalStack for local dev)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
S3_ENDPOINT_URL=http://localhost:4566
S3_RAW_BUCKET=factorymind-raw-dev
S3_DATASETS_BUCKET=factorymind-datasets-dev
S3_MODELS_BUCKET=factorymind-models-dev
S3_EXPORTS_BUCKET=factorymind-exports-dev

# Auth
JWT_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# W&B
WANDB_API_KEY=your-wandb-api-key-here
WANDB_PROJECT=factorymind
WANDB_ENTITY=your-wandb-username

# Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://factorymind:secret@postgres:5432/airflow

# Triton
TRITON_SERVER_URL=localhost:8001
